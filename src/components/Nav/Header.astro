---
import Logo from "@/components/Nav/Logo.astro";
import Nav from "@/components/Nav/Nav.astro";
import { cn } from "@/lib/utils";
interface Props {
    className?: string;
}

const { className } = Astro.props as Props;
const styles = cn(
    "py-3 w-full fixed top-0 left-0 right-0 z-[9999] flex flex-row items-center px-3 sm:px-5 bg-gr-600/90 backdrop-blur-md text-white shadow-lg shadow-black/10 transition-transform duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] [&_a:hover]:underline",
    className
);
---

<script>
    const header = document.querySelector("[data-header-nav]") as HTMLElement | null;
    if (header) {
        let lastY = window.scrollY;
        let ticking = false;

        const onScroll = () => {
            if (ticking) return;
            ticking = true;

            requestAnimationFrame(() => {
                const currentY = window.scrollY;
                const delta = currentY - lastY;
                const pastThreshold = currentY > 80;

                if (delta > 4 && pastThreshold) {
                    header.classList.add("header-hidden");
                } else if (delta < -4) {
                    header.classList.remove("header-hidden");
                }

                lastY = currentY;
                ticking = false;
            });
        };

        window.addEventListener("scroll", onScroll, { passive: true });
    }
</script>

<style>
    .header-hidden {
        transform: translateY(-100%) !important;
    }
</style>

<header class={styles} data-header-nav>
    <a href="/" class="flex flex-row items-center justify-between underline">
        <Logo loading="eager" />
        <h1 class="text-2xl ml-2">A l'Abord'Arbre</h1>
    </a>
    <div class="grow"></div>
    <Nav />
</header>
