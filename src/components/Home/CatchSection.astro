---
import CatchVideo from "@/components/CatchVideo.astro";
---

<script>
    import { setupIntersectionObserver } from "@/lib/utils";

    const topIntro = document.querySelector("[data-observer='a']") as HTMLElement | null;
    const p1 = document.querySelector("[data-observer='b']") as HTMLElement | null;
    const p2 = document.querySelector("[data-observer='c']") as HTMLElement | null;
    const video = document.querySelector("[data-observer='d']") as HTMLElement | null;

    if (topIntro) {
        setupIntersectionObserver(topIntro, {
            onIntersect: () => {
                topIntro.classList.add("reveal-from-bottom-base");
            },
        });
    }

    [p1, p2, video].forEach((element) => {
        if (!element) return;
        setupIntersectionObserver(element, {
            onIntersect: () => {
                element.classList.add("reveal-from-bottom-delayed");
            },
        });
    });
</script>

<section class="bg-map-dark relative overflow-hidden py-24 sm:py-32 px-5 md:px-10">
    <div class="absolute inset-0 bg-gradient-to-b from-fsky-700/15 via-transparent to-transparent pointer-events-none" />

    <div class="relative z-10 max-w-6xl mx-auto vertical gap-16 lg:gap-20">
        <div class="vertical center text-center gap-6 opacity-0 translate-y-[100%]" data-observer="a">
            <span class="inline-block text-gr-400 text-sm font-semibold tracking-widest uppercase">
                Découvrir la grimpe d'arbre
            </span>
            <h2 class="grandstander text-[clamp(1.8rem,5vw,3rem)] text-white leading-tight max-w-[20ch]">
                Un parc accrobranche chez vous !
            </h2>
            <div class="w-12 h-px bg-gradient-to-r from-transparent via-gr-400/60 to-transparent" />
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
            <div class="vertical gap-6 order-2 lg:order-1">
                <p
                    data-observer="b"
                    class="opacity-0 translate-y-[100%] text-lg md:text-xl font-medium text-white/90 leading-relaxed"
                    style="--reveal-delay: 0.4s">
                    Envie de te dépasser et de te reconnecter à la nature ? La grimpe d'arbre est faite pour toi !
                </p>
                <p
                    data-observer="c"
                    class="opacity-0 translate-y-[100%] text-[0.95rem] md:text-base text-map-darkblue/80 leading-relaxed"
                    style="--reveal-delay: 0.5s">
                    Accompagnés par nos éducateurs passionnés, explorez la sérénité des cimes en vous redécouvrant
                    dans un environnement extra-ordinaire. Chaque atelier est une invitation à ressentir des émotions
                    authentiques et à comprendre l'importance de préserver notre écosystème.
                </p>
            </div>

            <div class="order-1 lg:order-2">
                <CatchVideo
                    dataObserver="d"
                    style="--reveal-delay: 0.6s"
                    className="w-full object-cover rounded-xl shadow-2xl shadow-black/40 ring-1 ring-white/10 opacity-0 translate-y-[50%]"
                />
            </div>
        </div>
    </div>
</section>
