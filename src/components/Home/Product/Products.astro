---
import SensorielImage from "@/assets/client-img-56.jpeg";
import EvenementielImage from "@/assets/client-img-55.jpeg";
import RechercheImage from "@/assets/client-img-54.jpeg";
import ImmersionImage from "@/assets/client-img-57.jpeg";
import InitiationImage from "@/assets/client-img-58.jpeg";
import data from "@/components/shared/product-data/main-product.json" assert { type: "json" };
import ProductSection from "./ProductSection.astro";
import CardProduct from "./CardProduct.astro";
import type { Product, ProductData, ProductImage } from "./types";
import { capitalize } from "@/lib/utils";

const buildProducts = (data: ProductData): { simpleProducts: Product[]; withSubproducts: Product[] } => {
    const { poles, products } = data;
    const availableProducts = products.filter((p) => poles.enabledProductIds.includes(p.id));
    const simpleProducts = availableProducts.filter((p) => !p.subproducts);
    const withSubproducts = availableProducts.filter((p) => p.subproducts);
    return { simpleProducts, withSubproducts };
};
const productData: ProductData = data;
const { simpleProducts, withSubproducts } = buildProducts(productData);

const images: ProductImage[] = [
    {
        key: "evenementiel",
        src: EvenementielImage,
        alt: "Illustration d'un événement Alabordarbre avec des personnes souriantes en cercle, écoutant les instructions de l'animatrice Lou équipée sur corde",
        width: 1200,
        height: 800,
    },
    {
        key: "sensoriel",
        src: SensorielImage,
        alt: "Illustration d'un atelier sensoriel Alabordarbre où l'on aperçoit deux personnes grimpant dans le vide sur une corde",
        width: 1200,
        height: 800,
    },
    {
        key: "recherche",
        src: RechercheImage,
        alt: "Illustration d'un atelier de recherche Alabordarbre pendant lequel un groupe de personne est en train de chercher des indices au pied d'un arbre",
        width: 1200,
        height: 800,
    },
    {
        key: "initiation",
        src: InitiationImage,
        alt: "Illustration d'un atelier d'initiation à la grimpe d'arbre avec une personne encordée en progression",
        width: 1200,
        height: 800,
    },
    {
        key: "immersion",
        src: ImmersionImage,
        alt: "Illustration d'une immersion perchée en forêt avec des participants installés dans les arbres",
        width: 1200,
        height: 800,
    },
];

type OfferItem = {
    id: string;
    pole: string;
    title: string;
    description: string;
    tags: string[];
    price?: string;
    program?: string[];
    audience?: string;
    locations?: string;
    theme?: string;
    image: ProductImage;
    sortKey: number;
};

const normalizeLabel = (value: string) => value.trim().toLowerCase();
const imageByKey = new Map(images.map((image) => [normalizeLabel(image.key), image]));
const defaultImage = images[0];
const getImageForKey = (key?: string) => (key ? imageByKey.get(normalizeLabel(key)) : undefined) ?? defaultImage;
const normalizeProgram = (program: string[] | string | undefined): string[] => {
    if (!program) return [];
    return Array.isArray(program) ? program : [program];
};

const simpleOffers: OfferItem[] = simpleProducts.map((product) => ({
    id: `product-${product.id}`,
    pole: product.pole,
    title: product.title,
    description: capitalize(product.description || ""),
    tags: product.tags ?? [],
    price: product.price,
    program: normalizeProgram(product.program),
    audience: product.audience,
    locations: product.locations,
    image: getImageForKey(product.imageKey),
    sortKey: product.id * 1000,
}));

const subproductOffers: OfferItem[] = withSubproducts.flatMap((product) =>
    (product.subproducts ?? []).map((subproduct) => ({
        id: `subproduct-${product.id}-${subproduct.id}`,
        pole: product.pole,
        title: subproduct.title,
        description: subproduct.description,
        tags: [],
        program: normalizeProgram(subproduct.program),
        theme: subproduct.theme,
        image: getImageForKey(subproduct.imageKey),
        sortKey: product.id * 1000 + subproduct.id,
    })),
);

const offers: OfferItem[] = [...simpleOffers, ...subproductOffers];

const availablePoles = productData.poles.all.filter((pole) => productData.poles.enabledPoleIds.includes(pole.id));

const offersByPole = new Map<string, OfferItem[]>();
availablePoles.forEach((pole) => {
    const poleOffers = offers
        .filter((offer) => normalizeLabel(offer.pole) === normalizeLabel(pole.label))
        .sort((a, b) => a.sortKey - b.sortKey);
    offersByPole.set(pole.label, poleOffers);
});

const productIdByPoleLabel = new Map<string, number>();
productData.products.forEach((p) => {
    if (productData.poles.enabledProductIds.includes(p.id)) {
        productIdByPoleLabel.set(normalizeLabel(p.pole), p.id);
    }
});

const polesSortedByProductId = [...availablePoles].sort(
    (a, b) =>
        (productIdByPoleLabel.get(normalizeLabel(a.label)) ?? 999) -
        (productIdByPoleLabel.get(normalizeLabel(b.label)) ?? 999),
);

const poleIntro: Record<string, string> = {
    animation:
        "Deux formats complémentaires pour vivre la grimpe d'arbre : une initiation dynamique ou une immersion longue en nature.",
    evenementiel:
        "Des interventions sur-mesure pour vos festivals, anniversaires et événements afin de proposer une expérience marquante.",
    "sensoriel et sensibilisation":
        "Des ateliers accessibles et pédagogiques pour explorer, ressentir et sensibiliser à la protection de l'environnement.",
    recherche:
        "Des accompagnements scientifiques et techniques pour vos projets d'étude de la faune, de la flore et des milieux forestiers.",
};
---

<ProductSection title="Nos pôles d'activités et nos ateliers">
    <div class="vertical gap-20 md:gap-28 w-full">
        {
            polesSortedByProductId.map((pole) => {
                const poleOffers = offersByPole.get(pole.label) ?? [];
                const intro = poleIntro[normalizeLabel(pole.label)] ?? "";
                if (poleOffers.length === 0) return null;
                return (
                    <section class="vertical gap-8">
                        <header class="vertical gap-2 max-w-2xl" data-reveal="pole-header">
                            <h3 class="grandstander text-[clamp(1.4rem,3.5vw,1.9rem)] text-gr-600">
                                Pôle {capitalize(pole.label)}
                            </h3>
                            {intro && <p class="text-black/55 text-sm md:text-base leading-relaxed">{intro}</p>}
                        </header>
                        <div class="vertical gap-8">
                            {poleOffers.map(({ sortKey: _sk, ...offer }) => (
                                <CardProduct {...offer} />
                            ))}
                        </div>
                    </section>
                );
            })
        }
    </div>
</ProductSection>

<script>
    import { setupIntersectionObserver } from "@/lib/utils";

    const revealElements = document.querySelectorAll<HTMLElement>("[data-reveal]");

    revealElements.forEach((el) => {
        setupIntersectionObserver(el, {
            threshold: 0.15,
            rootMargin: "0px 0px -8% 0px",
            onIntersect: () => el.classList.add("revealed"),
            onDisappear: () => {},
            unobserve: true,
            debug: false,
        });
    });
</script>

<style is:global>
    [data-reveal="section-title"],
    [data-reveal="pole-header"] {
        opacity: 0;
        transform: translateY(1.2rem);
        transition:
            opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
            transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }
    [data-reveal="section-title"].revealed,
    [data-reveal="pole-header"].revealed {
        opacity: 1;
        transform: translateY(0);
    }

    [data-reveal="card-glass"] {
        opacity: 0;
        transform: translateY(1.8rem) scale(0.97);
        transition:
            opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
            transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    }
    [data-reveal="card-glass"].revealed {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    [data-reveal="program-row"] {
        opacity: 0;
        transform: translateX(-0.6rem);
        transition:
            opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1),
            transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--row-delay, 0ms);
    }
    [data-reveal="program-row"].revealed {
        opacity: 1;
        transform: translateX(0);
    }
</style>
