---
import Accordion from "./FAQs/Accordion.astro";
import CTA from "./shared/CTA.astro";
import Section from "../layouts/Section.astro";
import { ArrowDown, SearchIcon } from "lucide-react";
---

<style is:global>
    ::highlight(faq-search) {
        background-color: #fde68a;
        color: inherit;
    }
</style>
<Section className={"vertical items-center justify-start gap-0 mt-36"} size="full" extension="xl">
    <div class="text-center vertical center mb-20 px-5">
        <h2 class="text-[clamp(2.125rem,6vw,3rem)] uppercase mb-5">Questions fréquentes</h2>
        <p class="max-w-[50ch] mb-5 text-[1rem] text-balance">
            Retrouvez les réponses aux questions fréquentes sur notre fonctionnement, notre identité, les modalités de
            paiement et l'accès au lieu de grimpe.
        </p>
        <ArrowDown size="32" />
    </div>
    <div class="px-5 md:px-0 w-full md:w-9/12 h-full vertical justify-end">
        <script>
            const SEARCH_THRESHOLD = 2;
            const SEARCH_DEBOUNCE_MS = 200;

            const details = Array.from(document.querySelectorAll("[data-faq-root] details")) as HTMLDetailsElement[];
            const searchInput = document.getElementById("searchInput") as HTMLInputElement | null;
            let debounceId: ReturnType<typeof setTimeout> | undefined;
            const highlightName = "faq-search";
            const supportsHighlight = "highlights" in CSS && "Highlight" in window;

            // normalize all strings for further comparison
            const normalize = (str: string) =>
                str
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "")
                    .toLowerCase();

            const clearHighlight = () => {
                if (supportsHighlight) {
                    CSS.highlights.delete(highlightName);
                }
            };

            const collectTextNodes = (element: HTMLElement): Text[] => {
                const walker = document.createTreeWalker(element, NodeFilter.SHOW_TEXT);
                const nodes: Text[] = [];
                let currentNode = walker.nextNode();
                while (currentNode) {
                    const textNode = currentNode as Text;
                    if (textNode.textContent?.trim()) {
                        nodes.push(textNode);
                    }
                    currentNode = walker.nextNode();
                }
                return nodes;
            };

            const buildNormalizedMap = (value: string): { normalized: string; map: number[] } => {
                let normalized = "";
                const map: number[] = [];
                for (let index = 0; index < value.length; index++) {
                    const normalizedChunk = normalize(value[index] || "");
                    normalized += normalizedChunk;
                    for (let i = 0; i < normalizedChunk.length; i++) {
                        map.push(index);
                    }
                }
                return { normalized, map };
            };

            const createRangesForNode = (node: Text, normalizedQuery: string): Range[] => {
                const content = node.textContent ?? "";
                if (!content.trim()) return [];

                const { normalized, map } = buildNormalizedMap(content);
                if (!normalized || !normalizedQuery) return [];

                const ranges: Range[] = [];
                let cursor = 0;
                while (cursor < normalized.length) {
                    const start = normalized.indexOf(normalizedQuery, cursor);
                    if (start === -1) break;

                    const end = start + normalizedQuery.length - 1;
                    const startIndex = map[start];
                    const endIndex = (map[end] ?? content.length - 1) + 1;

                    if (startIndex !== undefined && endIndex > startIndex) {
                        const range = new Range();
                        range.setStart(node, startIndex);
                        range.setEnd(node, Math.min(endIndex, content.length));
                        ranges.push(range);
                    }

                    cursor = start + normalizedQuery.length;
                }

                return ranges;
            };

            const highlightMatches = (normalizedQuery: string) => {
                clearHighlight();
                if (!supportsHighlight || normalizedQuery.length <= SEARCH_THRESHOLD) return;

                const ranges: Range[] = [];
                faqs.forEach((faq) => {
                    if (faq.detail.hidden) return;
                    const textNodes = collectTextNodes(faq.detail);
                    textNodes.forEach((textNode) => {
                        ranges.push(...createRangesForNode(textNode, normalizedQuery));
                    });
                });

                if (ranges.length > 0) {
                    CSS.highlights.set(highlightName, new Highlight(...ranges));
                }
            };

            // retrieve all faqs from dom ( server -> html -> dom -> current script )
            const faqs = details.map((detail) => {
                const question = detail.querySelector("h4")?.textContent ?? "";
                const answers = Array.from(detail.querySelectorAll("p"))
                    .map((node) => node.textContent ?? "")
                    .join(" ");
                const faq = {
                    detail,
                    id: detail.querySelector("summary")?.id,
                    searchable: normalize(`${question} ${answers}`),
                };

                return faq;
            });

            // toggle visibility of details based on search input
            const applySearch = (rawValue: string) => {
                const value = rawValue.trim();

                if (value.length <= SEARCH_THRESHOLD) {
                    faqs.forEach((faq) => {
                        faq.detail.hidden = false;
                    });
                    clearHighlight();
                    return;
                }

                const search = normalize(value);

                faqs.forEach((faq) => {
                    const match = faq.searchable.includes(search);
                    faq.detail.hidden = !match;
                });
                highlightMatches(search);
            };

            if (searchInput) {
                searchInput.addEventListener("input", (e) => {
                    const input = e.target as HTMLInputElement;
                    clearTimeout(debounceId);
                    debounceId = setTimeout(() => {
                        applySearch(input.value);
                    }, SEARCH_DEBOUNCE_MS);
                });
            }
        </script>

        <search class="horizontal">
            <div class="vertical grow mb-5">
                <label class="font-medium text-gray-700" for="searchInput"> Chercher par mots-clés : </label>
                <div class="relative w-full mr-2">
                    <!-- onChange={handleSearch} -->
                    <input
                        id="searchInput"
                        type="text"
                        placeholder="Entrer un mot-clé.."
                        class="w-full py-2 pt-3 pl-10 pr-4 text-sm text-gray-900 placeholder-gray-700 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-black focus:border-black"
                    />
                    <SearchIcon
                        className="absolute w-5 h-5 text-gray-400 left-3 top-1/2 transition-colors -translate-y-[48%]"
                    />
                </div>
            </div>
        </search>

        <!-- DETAILS  -->
        <div data-faq-root>
            <Accordion single />
        </div>
    </div>
    <Section size="quarter" className={"vertical center mb-10 px-3"}>
        <div class="sm:flex sm:gap-3 justify-center items-center">
            <p class={`max-w-[35ch] sm:max-w-[50ch] grow`}>Vous n'avez pas trouvé votre réponse ?</p>
            <CTA href="/contact" prefetch prefetchType="hover" className="font-bold grow justify-end underline">
                Contactez-nous
            </CTA>
        </div>
    </Section>
</Section>
